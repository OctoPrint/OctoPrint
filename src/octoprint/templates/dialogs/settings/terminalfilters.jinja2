<h3>{{ _("Terminal Filters") }}</h3>
<form class="form-horizontal" onsubmit="return false;">
    <div class="row-fluid">
        <div class="span4">
            <h4>{{ _("Name") }}</h4>
        </div>
        <div class="span6">
            <h4>
                {{ _("RegExp") }} <small><a href="https://developer.mozilla.org/en/docs/Web/JavaScript/Guide/Regular_Expressions">?</a></small>
            </h4>
        </div>
    </div>
    <div data-bind="foreach: terminalFilters">
        <div class="row-fluid" style="margin-bottom: 5px">
            <div class="span4">
                <input type="text" class="span12" data-bind="value: name">
            </div>
            <div class="span6">
                <input type="text" class="span12" data-bind="value: regex">
            </div>
            <div class="span2">
                <a title="{{ _('Remove Filter') |edq }}"
                   class="btn btn-danger"
                   data-bind="click: $parent.removeTerminalFilter"><i class="far fa-trash-alt"></i></a>
                <a title="{{ _('Reset filter to default') |edq }}"
                   class="btn"
                   data-bind="visible: $parent.terminalFilterHasDefault($data), click: $parent.resetTerminalFilter, css: {disabled: $parent.terminalFilterMatchesDefault($data)}"><i class="fas fa-rotate-left"></i></a>
            </div>
        </div>
    </div>
    <div class="row-fluid">
        <div class="offset10 span2">
            <a title="{{ _('Add Filter') |edq }}"
               class="btn btn-primary"
               data-bind="click: addTerminalFilter"><i class="fas fa-plus"></i></a>
            <a title="{{ _('Reset all filters to defaults') |edq }}"
               class="btn"
               data-bind="click: resetAllTerminalFilters, css: {disabled: terminalFiltersMatchDefaults}"><i class="fas fa-rotate-left"></i></a>
        </div>
    </div>
</form>
