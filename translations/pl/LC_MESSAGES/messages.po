msgstr "Osiągnięcia i statystyki instancji"

#: src/octoprint/plugins/achievements/__init__.py:886
msgid ""
"Without this plugin you will no longer be able to earn achievements and "
"track stats about your OctoPrint instance."
msgstr ""
"Bez tej wtyczki nie będzie można zdobywać osiągnięć ani śledzić statystyk "
"instancji OctoPrint."

#: src/octoprint/plugins/achievements/static/js/achievements.js:68
msgid "No prints yet"
msgstr "Brak wydruków"

#: src/octoprint/plugins/achievements/static/js/achievements.js:70
#, python-format
msgid "%(prints)s (%(finished)s finished)"
msgstr "%(prints)s (%(finished)s ukończonych)"

