#: src/octoprint/templates/dialogs/firmwareerror.jinja2:4
msgid "There was an error reported by your printer"
msgstr "Drukarka zgłosiła błąd"

#: src/octoprint/templates/dialogs/firmwareerror.jinja2:7
msgid ""
"\n"
"\t\t\tYour printer's firmware reported an error:\n"
"\t\t"
msgstr ""
"\n"
"\t\t\tOprogramowanie układowe drukarki zgłosiło błąd:\n"
"\t\t"

#: src/octoprint/templates/dialogs/firmwareerror.jinja2:11
msgid ""
"\n"
"\t\t\tDue to this error, OctoPrint was not able to continue to communicate "
"with your printer and\n"
"\t\t\tsent an emergency stop command <code>M112</code> to ensure all heaters "
"are turned off, then disconnected.\n"
"\t\t"
msgstr ""
"\n"
"\t\t\tZ powodu tego błędu OctoPrint nie mógł kontynuować komunikacji z "
"drukarką i\n"
"\t\t\twysłał polecenie awaryjnego zatrzymania <code>M112</code>, aby "
"wyłączyć wszystkie grzałki,\n"
"\t\t\ta następnie rozłączył połączenie.\n"
"\t\t"

#: src/octoprint/templates/dialogs/firmwareerror.jinja2:15
msgid ""
"\n"
"\t\t\tDue to this error, OctoPrint was not able to continue to communicate "
"with your printer and\n"
"\t\t\thad to disconnect.\n"
"\t\t"
msgstr ""
"\n"
"\t\t\tZ powodu tego błędu OctoPrint nie mógł kontynuować komunikacji z "
"drukarką\n"
"\t\t\ti musiał się rozłączyć.\n"
"\t\t"

#: src/octoprint/templates/dialogs/firmwareerror.jinja2:19
msgid ""
"\n"
"\t\t\tDue to this error, OctoPrint cancelled the ongoing print job.\n"
"\t\t"
msgstr ""
"\n"
"\t\t\tZ powodu tego błędu OctoPrint anulował trwające zadanie drukowania.\n"
"\t\t"

#: src/octoprint/templates/dialogs/firmwareerror.jinja2:22
msgid ""
"\n"
"\t\t\tYou might be able to find more information on this error and how to "
"solve it\n"
"\t\t\t<a target=\"_blank\" rel=\"noreferrer noopener\">in this FAQ entry</"
"a>!\n"
"\t\t"
msgstr ""
"\n"
"\t\t\tWięcej informacji o tym błędzie i sposobach jego rozwiązania "
"znajdziesz\n"
"\t\t\t<a target=\"_blank\" rel=\"noreferrer noopener\">w tym wpisie FAQ</"
"a>!\n"
"\t\t"

#: src/octoprint/templates/dialogs/firmwareerror.jinja2:27
msgid ""
"\n"
"\t\t\t\tHere's the last communication with your printer before this error "
"occurred:\n"
"\t\t\t"
msgstr ""
"\n"
"\t\t\t\tOto ostatnia komunikacja z drukarką przed wystąpieniem błędu:\n"
"\t\t\t"

#: src/octoprint/templates/dialogs/firmwareerror.jinja2:31
msgid ""
"\n"
"\t\t\t\tThis error is not caused by OctoPrint, it is a problem that was "
"reported by your printer's firmware to which OctoPrint reacted!\n"
"\t\t\t"
msgstr ""
"\n"
"\t\t\t\tTen błąd nie został spowodowany przez OctoPrint — został zgłoszony "
"przez firmware drukarki,\n"
"\t\t\t\n"
"a OctoPrint jedynie na niego zareagował!\n"
"\t\t\t"

