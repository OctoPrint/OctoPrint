msgstr "Losowy unikalny identyfikator instancji"

#: src/octoprint/plugins/errortracking/templates/errortracking_settings.jinja2:28
#: src/octoprint/plugins/tracking/templates/tracking_settings.jinja2:14
msgid "Instance ID"
msgstr "ID instancji"

#: src/octoprint/plugins/errortracking/templates/errortracking_settings.jinja2:35
msgid ""
"\n"
"<p>\n"
"    The Error Tracking plugin is using a Sentry instance kindly provided by\n"
"    <a href=\"https://sentry.io/\" target=\"_blank\" rel=\"noopener "
"noreferer\">sentry.io</a>. For information on their service\n"
"    please refer to their <a href=\"https://sentry.io/security/\" "
"target=\"_blank\" rel=\"noopener noreferer\">Security & Compliance "
"documentation</a>\n"
"    and their <a href=\"https://sentry.io/privacy/\" target=\"_blank\" "
"rel=\"noopener noreferer\">Privacy Policy</a>.\n"
"</p>\n"
msgstr ""
"\n"
"<p>\n"
"    Wtyczka Śledzenie błędów korzysta z instancji Sentry udostępnionej "
"przez\n"
"    <a href=\"https://sentry.io/\" target=\"_blank\" rel=\"noopener "
"noreferer\">sentry.io</a>. Informacje o usłudze znajdziesz w\n"
"    <a href=\"https://sentry.io/security/\" target=\"_blank\" rel=\"noopener "
"noreferer\">dokumentacji Security & Compliance</a>\n"
"    oraz w <a href=\"https://sentry.io/privacy/\" target=\"_blank\" "
"rel=\"noopener noreferer\">Polityce prywatności</a>.\n"
"</p>\n"

