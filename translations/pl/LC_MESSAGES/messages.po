msgstr "Próg rozmiaru pliku"

#: src/octoprint/plugins/gcodeviewer/templates/gcodeviewer_settings.jinja2:16
msgid "on desktop"
msgstr "na komputerze"

#: src/octoprint/plugins/gcodeviewer/templates/gcodeviewer_settings.jinja2:20
msgid "on mobile"
msgstr "na urządzeniu mobilnym"

