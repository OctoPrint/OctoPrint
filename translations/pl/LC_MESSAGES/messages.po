#, python-format
msgid "%(total)s"
msgstr "%(total)s"

#: src/octoprint/plugins/achievements/static/js/achievements.js:96
#, python-format
msgid "%(total)s (%(finished)s finished)"
msgstr "%(total)s (%(finished)s ukończonych)"

