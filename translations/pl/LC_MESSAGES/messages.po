#: src/octoprint/plugins/action_command_notification/templates/action_command_notification_settings.jinja2:23
#, python-format
msgid ""
"Use this to write a valid <em>regular expression</em> to hide notifications "
"having the pattern defined in it. Chain multiple filters using \"|\". For "
"more information, please see <a href=\"%%(tut_url)s\" target=\"_blank\" "
"rel=\"noopener noreferer\">the Python docs on regular expressions</a>"
msgstr ""
"Użyj tego pola, aby wpisać poprawne <em>wyrażenie regularne</em> ukrywające "
"powiadomienia pasujące do wzorca. Możesz łączyć wiele filtrów za pomocą \"|"
"\". Więcej informacji znajdziesz w <a href=\"%%(tut_url)s\" "
"target=\"_blank\" rel=\"noopener noreferer\">dokumentacji Pythona dotyczącej "
"wyrażeń regularnych</a>"

