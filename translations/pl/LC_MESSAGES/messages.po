#: src/octoprint/access/permissions.py:274
msgid "Admin is allowed to do everything"
msgstr "Administrator ma pełne uprawnienia"

#: src/octoprint/access/permissions.py:282
msgid ""
"Allows to gather basic status information, e.g. job progress, printer state, "
"temperatures, ... Mandatory for the default UI to work"
msgstr ""
"Pozwala pobierać podstawowe informacje o stanie, np. postęp zadania, stan "
"drukarki, temperatury itd. Wymagane do działania domyślnego interfejsu"

#: src/octoprint/access/permissions.py:293
msgid "Allows to connect to and disconnect from a printer"
msgstr "Pozwala łączyć się z drukarką i rozłączać ją"

#: src/octoprint/access/permissions.py:300
msgid "Allows to watch the webcam stream"
msgstr "Pozwala oglądać strumień z kamery"

#: src/octoprint/access/permissions.py:307
msgid ""
"Allows to run system commands, e.g. restart OctoPrint, shutdown or reboot "
"the system, and to retrieve system and usage information"
msgstr ""
"Pozwala uruchamiać polecenia systemowe, np. restart OctoPrint, wyłączenie "
"lub ponowne uruchomienie systemu oraz pobieranie informacji o systemie i "
"użyciu"

#: src/octoprint/access/permissions.py:317
msgid ""
"Allows to retrieve a list of all uploaded files and folders, includingtheir "
"metadata (e.g. date, file size, analysis results, ...)"
msgstr ""
"Pozwala pobrać listę wszystkich przesłanych plików i folderów wraz z ich "
"metadanymi (np. data, rozmiar pliku, wyniki analizy itd.)"

#: src/octoprint/access/permissions.py:326
msgid ""
"Allows users to upload new files, create new folders and copy existing ones. "
"If the File Delete permission is also set, File Upload also allows moving "
"files and folders."
msgstr ""
"Pozwala użytkownikom przesyłać nowe pliki, tworzyć nowe foldery i kopiować "
"istniejące. Jeśli ustawione jest także uprawnienie Usuwanie plików, "
"Przesyłanie plików pozwala również przenosić pliki i foldery."

#: src/octoprint/access/permissions.py:336
msgid ""
"Allows users to download files. The GCODE viewer is affected by this as well."
msgstr ""
"Pozwala użytkownikom pobierać pliki. Dotyczy to również podglądu GCODE."

#: src/octoprint/access/permissions.py:345
msgid ""
"Allows users to delete files and folders. If the File Upload permission is "
"also set, File Delete also allows moving files and folders."
msgstr ""
"Pozwala użytkownikom usuwać pliki i foldery. Jeśli ustawione jest także "
"uprawnienie Przesyłanie plików, Usuwanie plików pozwala również przenosić "
"pliki i foldery."

#: src/octoprint/access/permissions.py:354
msgid "Allows to select a file for printing"
msgstr "Pozwala wybrać plik do drukowania"

#: src/octoprint/access/permissions.py:361
msgid "Allows to start, pause and cancel a print job"
msgstr "Pozwala rozpocząć, wstrzymać i anulować zadanie drukowania"

#: src/octoprint/access/permissions.py:368
msgid ""
"Allows access to the GCODE viewer if the \"File Download\"permission is also "
"set."
msgstr ""
"Pozwala uzyskać dostęp do podglądu GCODE, jeśli ustawione jest także "
"uprawnienie „Pobieranie plików”."

#: src/octoprint/access/permissions.py:378
msgid ""
"Allows to watch the terminal tab but not to send commands to the printer "
"from it"
msgstr ""
"Pozwala przeglądać kartę terminala, ale bez wysyłania poleceń do drukarki"

#: src/octoprint/access/permissions.py:388
msgid ""
"Allows to control of the printer by using the temperature controls,the "
"control tab or sending commands through the terminal."
msgstr ""
"Pozwala sterować drukarką za pomocą kontroli temperatury, zakładki "
"Sterowanie lub wysyłania poleceń przez terminal."

#: src/octoprint/access/permissions.py:398
msgid "Allows to slice files"
msgstr "Pozwala na cięcie (slicing) plików"

#: src/octoprint/access/permissions.py:405
msgid "Allows to list timelapse videos"
msgstr "Pozwala wyświetlać listę filmów timelapse"

#: src/octoprint/access/permissions.py:411
msgid "Allows to download timelapse videos"
msgstr "Pozwala pobierać filmy timelapse"

#: src/octoprint/access/permissions.py:417
msgid "Allows to delete timelapse videos"
msgstr "Pozwala usuwać filmy timelapse"

#: src/octoprint/access/permissions.py:423
msgid "Allows to list, delete and render unrendered timelapses"
msgstr "Pozwala wyświetlać, usuwać i renderować niezrenderowane timelapse"

#: src/octoprint/access/permissions.py:429
msgid "Allows to change the timelapse settings."
msgstr "Pozwala zmieniać ustawienia timelapse."

#: src/octoprint/access/permissions.py:436
msgid ""
"Allows to read non sensitive settings. Mandatory for the default UI to work."
msgstr ""
"Pozwala odczytywać ustawienia niewrażliwe. Wymagane do działania domyślnego "
"interfejsu."

#: src/octoprint/access/permissions.py:445
msgid "Allows to manage settings and also to read sensitive settings"
msgstr "Pozwala zarządzać ustawieniami oraz odczytywać ustawienia wrażliwe"

#: src/octoprint/plugins/achievements/__init__.py:129
msgid "Allows to view the instance achievements & stats."
msgstr "Pozwala przeglądać osiągnięcia i statystyki instancji."

#: src/octoprint/plugins/achievements/__init__.py:138
msgid "Allows to reset the instance achievements & stats."
msgstr "Pozwala resetować osiągnięcia i statystyki instancji."

